# Database Configuration
DB_SERVER=localhost
DB_PORT=3306
DB_NAME=Life4DunDb
DB_USER=root
DB_PASSWORD=

# API Configuration
API_PORT=5000
API_HOST=0.0.0.0
ENVIRONMENT=Development

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-this-in-production-with-min-32-characters
JWT_ISSUER=Life4DunBackend
JWT_AUDIENCE=Life4DunClients
JWT_EXPIRATION_MINUTES=60

# Game Settings
MAX_PLAYERS=100
GAME_SESSION_TIMEOUT=3600
MAX_CONNECTIONS_PER_IP=10

# Logging
LOG_LEVEL=Information
LOG_FILE_PATH=./logs/app.log

# CORS Settings
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Redis Cache (Optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Security
ALLOW_ORIGINS=*
